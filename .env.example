APP_NAME=Dot Swahili API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@REAL_HOST:5432/DBNAME
ALEMBIC_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@REAL_HOST:5432/DBNAME

WEATHER_PROVIDER=visual_crossing
VISUAL_CROSSING_API_KEY=
VISUAL_CROSSING_BASE_URL=https://weather.visualcrossing.com/VisualCrossingWebServices/rest/services/timeline
WEATHER_TIMEOUT_SECONDS=15
WEATHER_RETRY_ATTEMPTS=3
WEATHER_RETRY_BACKOFF_SECONDS=1.0
WEATHER_MOCK_FALLBACK=true

SMS_PROVIDER=mock
SMS_ALLOWED_NUMBERS=
SMS_FROM_NUMBER=DOTSWAHILI
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
VOICE_ENABLED=true
TWILIO_VOICE_FROM_NUMBER=
TWILIO_VOICE_TWIML_URL=https://dot-swahili-775881330691.europe-west1.run.app/api/v1/voice/twiml
TWILIO_VOICE_STATUS_CALLBACK_URL=https://dot-swahili-775881330691.europe-west1.run.app/api/v1/voice/status
SMS_WEBHOOK_TOKEN=local-webhook-token

SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=1
ALERT_COOLDOWN_HOURS=12
RAIN_24H_THRESHOLD_MM=35
DROUGHT_72H_THRESHOLD_MM=5
HEAT_THRESHOLD_C=34
STORM_WIND_THRESHOLD_KPH=45

RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
SEED_SAMPLE_DATA=true
